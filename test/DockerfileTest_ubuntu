# Dockerfile to test core analyzer against ptmalloc/tcmalloc/jemalloc
# Tested base images:
#     debian:trixie, debian:bullseye, debian:bookworm(gdb 12.1 only)
#     ubuntu:24.04, ubuntu:22.04, ubuntu:20.04
# ==============================================================================================

ARG VARIANT=latest
FROM ${VARIANT}

WORKDIR /workspaces/core_analyzer/
COPY . .

RUN ./test/setup_ubuntu.sh

RUN echo 'set pagination off' > /root/.gdbinit

ARG GDB_VERSION=latest

WORKDIR /workspaces/core_analyzer/
RUN ./build_gdb.sh ${GDB_VERSION}
WORKDIR test
RUN make check

ARG SKIP_MIMALLOC
RUN if [[ -z "$SKIP_MIMALLOC" ]] ; then \
		cd /workspaces/core_analyzer/ && ./build_mimalloc.sh 3.2.8 && \
		cd test && make check-mimalloc ; \
		cd /workspaces/core_analyzer/ && ./build_mimalloc.sh 2.2.7 && \
		cd test && make check-mimalloc ; \
	fi

WORKDIR /workspaces/core_analyzer/
RUN ./build_jemalloc.sh 5.3.0
WORKDIR test
RUN make check-jemalloc

WORKDIR /workspaces/core_analyzer/
RUN ./build_jemalloc.sh 5.2.1
WORKDIR test
RUN make check-jemalloc

WORKDIR /workspaces/core_analyzer/
RUN ./build_tcmalloc.sh 2.18.1
WORKDIR test
RUN make check-tcmalloc

WORKDIR /workspaces/core_analyzer/
RUN ./build_tcmalloc.sh 2.17.2
WORKDIR test
RUN make check-tcmalloc

WORKDIR /workspaces/core_analyzer/
RUN ./build_tcmalloc.sh 2.16.90
WORKDIR test
RUN make check-tcmalloc
